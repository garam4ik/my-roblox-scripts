-- Теоретичний приклад зміни орієнтації деталі відносно персонажа
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Приклад створення об'єкта та налаштування його повороту
local item = Instance.new("Part")
item.Size = Vector3.new(2, 2, 2)
item.Color = Color3.fromRGB(85, 255, 85)
item.CanCollide = false
item.Parent = rootPart

local weld = Instance.new("Weld")
weld.Part0 = rootPart
weld.Part1 = item

-- math.rad(180) перевертає об'єкт рівно на 180 градусів по осі X
weld.C0 = CFrame.new(0, 0, 0) * CFrame.Angles(math.rad(180), 0, 0)
weld.Parent = item
