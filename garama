local oldGui = game.CoreGui:FindFirstChild("CocoMM2_MegaGui") or game.Players.LocalPlayer:FindFirstChildOfClass("PlayerGui"):FindFirstChild("CocoMM2_MegaGui")
if oldGui then oldGui:Destroy() end

local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

-- Змінні для функцій
local Noclip = false
local Speed = 16
local Jump = 50
local XrayActive = false
local AutoFarm = false
local KillAura = false
local SpinActive = false
local FixedY = 0

local Platform = Instance.new("Part")
Platform.Size = Vector3.new(6, 1, 6)
Platform.Anchored = true
Platform.Transparency = 1
Platform.CanCollide = false
Platform.Parent = workspace

local Spin = Instance.new("BodyAngularVelocity")
Spin.MaxTorque = Vector3.new(0, math.huge, 0)
Spin.AngularVelocity = Vector3.new(0, 5000, 0)

-- Допоміжні функції
local function UpdateMovement()
    if Humanoid then
        Humanoid.WalkSpeed = Speed
        Humanoid.JumpPower = Jump
    end
end

Player.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    RootPart = char:WaitForChild("HumanoidRootPart")
    UpdateMovement()
end)

-- Головний цикл фізики (Noclip, Платформа, Крутилка)
game:GetService("RunService").Stepped:Connect(function()
    if Character and RootPart and Humanoid then
        if Noclip or SpinActive then
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
        if SpinActive then
            RootPart.Velocity = Vector3.new(RootPart.Velocity.X, 0, RootPart.Velocity.Z)
            RootPart.CFrame = CFrame.new(RootPart.Position.X, FixedY, RootPart.Position.Z) * CFrame.Angles(0, math.rad(RootPart.Orientation.Y), 0)
            Platform.CanCollide = true
            Platform.CFrame = CFrame.new(RootPart.Position.X, FixedY - 2.2, RootPart.Position.Z)
            Spin.Parent = RootPart
        else
            if not AutoFarm then
                Platform.CanCollide = false
                Platform.CFrame = CFrame.new(0, 9999, 0)
            end
            Spin.Parent = nil
        end
    end
end)

