local oldGui = game.CoreGui:FindFirstChild("CocoTT2_Gui") or game.Players.LocalPlayer:FindFirstChildOfClass("PlayerGui"):FindFirstChild("CocoTT2_Gui")
if oldGui then oldGui:Destroy() end

local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

local PushActive = false
local Speed = 150

-- Створення платформи під гравцем
local Platform = Instance.new("Part")
Platform.Size = Vector3.new(4, 1, 4)
Platform.Anchored = true
Platform.Transparency = 1
Platform.CanCollide = false
Platform.Parent = workspace

-- Функція перетворення на МАЛЕНЬКИЙ квадрат
local function MakeSmallCube()
    if Character then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = 1
            elseif part:IsA("CharacterMesh") or part:IsA("Shirt") or part:IsA("Pants") or part:IsA("Accessory") then
                part:Destroy()
            end
        end
        
        if not RootPart:FindFirstChild("VisualCube") then
            local Cube = Instance.new("Part")
            Cube.Name = "VisualCube"
            Cube.Size = Vector3.new(1.2, 1.2, 1.2) -- Маленький розмір кубика
            Cube.Color = Color3.fromRGB(255, 85, 85) -- Робимо його яскравим
            Cube.CanCollide = false
            Cube.Parent = RootPart
            
            local Weld = Instance.new("Weld")
            Weld.Part0 = RootPart
            Weld.Part1 = Cube
            Weld.C0 = CFrame.new(0, 0, 0)
            Weld.Parent = Cube
        end
    end
end

local function UpdateWalkSpeed()
    if Humanoid then Humanoid.WalkSpeed = Speed end
end

Player.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    RootPart = char:WaitForChild("HumanoidRootPart")
    task.wait(0.5)
    MakeSmallCube()
    UpdateWalkSpeed()
end)

-- Логіка виштовхування інших гравців (Кілл-аура / Штовхач)
task.spawn(function()
    while true do
        if PushActive and RootPart then
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local EnemyRoot = p.Character.HumanoidRootPart
                    local Distance = (RootPart.Position - EnemyRoot.Position).Magnitude
                    
                    -- Якщо гравець ближче ніж на 12 studs, він летить геть
                    if Distance < 12 then
                        local Direction = (EnemyRoot.Position - RootPart.Position).Unit
                        -- Створюємо потужний імпульс швидкості для ворога
                        local Velocity = Instance.new("LinearVelocity")
                        Velocity.MaxForce = math.huge
                        Velocity.VectorVelocity = (Direction + Vector3.new(0, 1, 0)).Unit * 500 -- Напрямок польоту вгору і вбік
                        
                        local Attachment = Instance.new("Attachment")
                        Attachment.Parent = EnemyRoot
                        Velocity.Attachment0 = Attachment
                        Velocity.Parent = EnemyRoot
                        
                        -- Видаляємо імпульс через 0.1 сек, щоб вони просто летіли по інерції
                        task.defer(function()
                            task.wait(0.1)
                            Velocity:Destroy()
                            Attachment:Destroy()
                        end)
                    end
                end
            end
        end
        task.wait(0.05)
    end
end)

-- Основний цикл Ноукліпу та Платформи
game:GetService("RunService").Stepped:Connect(function()
    if Character and Humanoid and RootPart then
        if PushActive then
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            Platform.CanCollide = true
            Platform.CFrame = RootPart.CFrame * CFrame.new(0, -2.1, 0)
        else
            Platform.CanCollide = false
            Platform.CFrame = CFrame.new(0, 9999, 0)
        end
    end
end)

