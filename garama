    if SpinActive and RootPart then FixedY = RootPart.Position.Y end
end)

CreateButton(TabFun, "Зробити тіло Маленьким Кубом", function()
    for _, part in pairs(Character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then part.Transparency = 1
        elseif part:IsA("CharacterMesh") or part:IsA("Shirt") or part:IsA("Pants") or part:IsA("Accessory") then part:Destroy() end
    end
    if not RootPart:FindFirstChild("VisualCube") then
        local Cube = Instance.new("Part")
        Cube.Name = "VisualCube"
        Cube.Size = Vector3.new(1.5, 1.5, 1.5)
        Cube.Color = Color3.fromRGB(85, 255, 85)
        Cube.CanCollide = false
        Cube.Parent = RootPart
        local Weld = Instance.new("Weld")
        Weld.Part0 = RootPart Weld.Part1 = Cube Weld.Parent = Cube
    end
end)

